{
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(gh *)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/dev/repos/griffin/slack-notify/hook-handler.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/dev/repos/griffin/slack-notify/hook-handler.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "dotnet-skills": {
      "source": {
        "source": "github",
        "repo": "Aaronontheweb/dotnet-skills"
      }
    }
  },
  "autoMemoryEnabled": false,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "enabledPlugins": {
    "dotnet-skills@dotnet-skills": true
  }
}
